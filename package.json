{
  "name": "okrapdf",
  "version": "0.11.0",
  "description": "OkraPDF — upload a PDF, get an API. Runtime client, React hooks, and CLI.",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./doc": {
      "import": {
        "types": "./dist/url.d.ts",
        "default": "./dist/url.js"
      }
    },
    "./browser": {
      "import": {
        "types": "./dist/browser.d.ts",
        "default": "./dist/browser.js"
      }
    },
    "./worker": {
      "import": {
        "types": "./dist/worker.d.ts",
        "default": "./dist/worker.js"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      }
    },
    "./cli": {
      "import": {
        "types": "./dist/cli/index.d.ts",
        "default": "./dist/cli/index.js"
      }
    }
  },
  "bin": {
    "okra": "./dist/cli/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.2.0",
    "@types/ws": "^8.18.1",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/okrapdf/okrapdf"
  },
  "homepage": "https://okrapdf.com",
  "author": "OkraPDF",
  "keywords": [
    "pdf",
    "ocr",
    "document",
    "extraction",
    "api",
    "sdk",
    "structured-output"
  ],
  "publishConfig": {
    "access": "public"
  }
}
